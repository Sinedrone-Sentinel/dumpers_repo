# =============================================================================
# Dumper's Repo Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# See docs/SUPABASE_SETUP.md for setup instructions.
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED: Supabase Configuration
# -----------------------------------------------------------------------------
# Get these from your Supabase project dashboard (Settings → API)

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# -----------------------------------------------------------------------------
# OPTIONAL: Build Configuration
# -----------------------------------------------------------------------------
# Build identifier for cache busting (auto-set in CI via GITHUB_SHA)
# VITE_BUILD_ID=local

# -----------------------------------------------------------------------------
# DEVELOPMENT ONLY: DFP Engine Override
# -----------------------------------------------------------------------------
# Load DFP from local public/ instead of canonical host.
# WARNING: Production franchises MUST use the canonical DFP host per LICENSE.
# Only uncomment this for local development after running: npm run build-dfp
# VITE_DFP_ENGINE_BASE_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# NOT IN THIS FILE (set in Supabase dashboard)
# -----------------------------------------------------------------------------
# The following are used by Edge Functions and should NOT be in frontend env:
#
# SUPABASE_SERVICE_ROLE_KEY - Required for ban-user, unban-user, delete-account
#                             Auto-available in Supabase Edge Functions environment
#
# Never expose service_role key in frontend code or commit it to the repository.
